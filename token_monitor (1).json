      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let totalTokens = 0;\nconst execution = $(\"Get an execution\").item.json;\nconst runData = execution.data?.resultData?.runData;\n\n// 1. SAFETY: Ignore the monitor itself to prevent fake massive numbers\nif (execution.workflowId === \"k5yLopQQMTGBvryk\") {\n    return { workflowName: $json.name, tokensUsed: 0, status: \"Monitor Ignored\" };\n}\n\nif (runData) {\n    for (const nodeName in runData) {\n        const nodeRuns = runData[nodeName];\n        \n        nodeRuns.forEach(run => {\n            // n8n 2.0 stores node results in run.data.main\n            if (run.data?.main) {\n                run.data.main.forEach(itemArray => {\n                    itemArray.forEach(item => {\n                        const nodeOutput = item.json;\n                        if (!nodeOutput) return;\n\n                        // Path 1: Google Gemini (The one in your JSON)\n                        if (nodeOutput.usageMetadata) {\n                            totalTokens += (nodeOutput.usageMetadata.totalTokenCount || 0);\n                        }\n\n                        // Path 2: OpenAI, Groq, Grok, Anthropic\n                        if (nodeOutput.usage) {\n                            totalTokens += (nodeOutput.usage.totalTokens || nodeOutput.usage.total_tokens || 0);\n                        }\n                    });\n                });\n            }\n\n            // Path 3: AI Agent \"Intermediate Steps\" (In case you use an Agent later)\n            if (run.data?.intermediateSteps) {\n                run.data.intermediateSteps.forEach(step => {\n                    const stepUsage = step.response?.usageMetadata || step.response?.usage;\n                    if (stepUsage) {\n                        totalTokens += (stepUsage.totalTokenCount || stepUsage.totalTokens || stepUsage.total_tokens || 0);\n                    }\n                });\n            }\n        });\n    }\n}\n\nreturn {\n    workflowName: $json.name,\n    executionId: execution.id,\n    status: execution.status,\n    tokensUsed: totalTokens,\n    timestamp: execution.stoppedAt\n};"
      },
