        "mode": "runOnceForEachItem",
        "jsCode": "// 1. All these values are now inside $json because of the Merge node\nconst tokens = $json.tokensUsed || 0;\nconst wfName = $json.workflowName || \"Unknown Workflow\";\nconst currentStatus = $json.status || \"success\"; // Grab status from Merge output\n\n// 2. Database values (also from Merge output)\nconst avg = $json.avg_token || 0;\nconst count = $json.execution_count || 0;\n\n// 3. Anomaly Logic\nconst isAnomaly = tokens > (avg * 2) && tokens > 50000;\n\n// 4. Calculate new values\nconst nextCount = count + 1;\nconst nextAvg = Math.round(((avg * count) + tokens) / nextCount);\n\nreturn {\n  workflowName: wfName,\n  tokensUsed: tokens,\n  isAnomaly: isAnomaly,\n  status: currentStatus, // Pass the status through correctly\n  oldAvg: avg,\n  newAvg: nextAvg,\n  newCount: nextCount\n};"
      },
